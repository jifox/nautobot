##############################################################################
# Settings for plugin "nautobot_golden_config"
# see: https://github.com/nautobot/nautobot-plugin-golden-config#installation

# # A list of platforms supported, identified by the platform_slug, with special consideration for all.
# ALLOWED_OS=all

# # A boolean to represent whether or not to run backup configurations within the plugin
# ENABLE_BACKUP=True

# # A boolean to represent whether or not to run the compliance process within the plugin.
# ENABLE_COMPLIANCE=True

# # A boolean to represent whether or not to generate intended configurations within the plugin.
# ENABLE_INTENDED=True

# # A boolean to represent whether or not to provide a GraphQL query per device to allow the intended configuration to provide data variables to the plugin.
# ENABLE_SOTAGG=True

# # A string representation of a function that can post-process the graphQL data.
# SOT_AGG_TRANSPOSER=""
